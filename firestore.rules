rules_version = '2';

// 동작 우선 MVP 규칙(간단 버전)
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function isHost(roomId) {
      return signedIn() && room(roomId).data.hostUid == request.auth.uid;
    }

    function isBotUid(uid) {
      return uid.matches('^bot_.+');
    }

    match /roomCodes/{code} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.roomId is string
        && "createdAt" in request.resource.data;
      allow update: if false;
      allow delete: if signedIn();
    }

    match /rooms/{roomId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.status == "lobby"
        && request.resource.data.roomCode is string;

      allow update: if signedIn() && (
        // 호스트는 로비/종료 상태 운영 권한
        isHost(roomId) ||
        // 플레이 중: 현재 턴 플레이어만 public game 갱신
        (
          room(roomId).data.status == "playing"
          && request.auth.uid == room(roomId).data.game.currentUid
          && request.resource.data.game.version == room(roomId).data.game.version + 1
        ) ||
        // 플레이 중: 현재 턴이 봇이면 호스트가 대리 갱신
        (
          room(roomId).data.status == "playing"
          && room(roomId).data.game.currentUid.matches('^bot_.+')
          && isHost(roomId)
          && request.resource.data.game.version == room(roomId).data.game.version + 1
        ) ||
        // 리액션 필드만 변경
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["reactions"]) ||
        // 게임 종료 후 로비 전환
        (
          room(roomId).data.status == "ended"
          && request.resource.data.status == "lobby"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
        ) ||
        // 호스트 위임
        (
          room(roomId).data.status == "lobby"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["hostUid", "updatedAt"])
        )
      );

      allow delete: if signedIn()
        && room(roomId).data.status == "lobby"
        && room(roomId).data.hostUid == request.auth.uid;

      match /players/{uid} {
        allow read: if signedIn();

        allow create: if signedIn() && (
          request.auth.uid == uid ||
          (isHost(roomId) && isBotUid(uid))
        );

        allow update: if signedIn() && (
          request.auth.uid == uid ||
          isHost(roomId)
        );

        allow delete: if signedIn() && (
          request.auth.uid == uid ||
          isHost(roomId) ||
          room(roomId).data.status == "ended"
        );
      }

      match /privateHands/{uid} {
        allow read, create, update: if signedIn() && (
          request.auth.uid == uid ||
          isHost(roomId)
        );
        allow delete: if false;
      }

      match /privateDealer/{docId} {
        allow read, write: if signedIn() && (
          isHost(roomId) ||
          request.auth.uid == room(roomId).data.game.currentUid
        );
      }
    }
  }
}
